# Database
DATABASE_URL="postgresql://user:password@host:5432/zircuvia?sslmode=require"

# Auth
JWT_SECRET="CHANGE_ME_generate_with_openssl_rand_hex_32"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Xendit (optional — mock mode works without these)
XENDIT_MODE="mock"
XENDIT_SECRET_KEY=""
XENDIT_WEBHOOK_TOKEN=""

# Email (Mailjet) — optional, falls back to mock mode if not set
MAILJET_API_KEY=""
MAILJET_SECRET_KEY=""
MAILJET_FROM_EMAIL="noreply@zircuvia.com"
MAILJET_FROM_NAME="ZircuVia"
